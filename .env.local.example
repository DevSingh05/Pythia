# Pythia Backend API
# Set this to your backend URL to enable real options pricing and order placement.
# If unset, the frontend computes options locally via the Logit-Normal model
# and fetches market data directly from Polymarket's Gamma API.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Polymarket API (only needed if overriding the default)
NEXT_PUBLIC_POLYMARKET_API=https://gamma-api.polymarket.com
