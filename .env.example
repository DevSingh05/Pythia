# ── Upstash Redis ──────────────────────────────────────────────────────────────
UPSTASH_REDIS_URL=https://your-instance.upstash.io
UPSTASH_REDIS_TOKEN=your-token-here

# ── Neon Postgres ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── Service URLs (filled by docker-compose / Fly.io env) ──────────────────────
PRICING_SERVICE_URL=http://localhost:8000
MARKET_DATA_SERVICE_URL=http://localhost:3001

# ── Frontend public vars (exposed to browser) ─────────────────────────────────
# (none — all API calls go through Next.js route handlers)

# ── Optional ──────────────────────────────────────────────────────────────────
# PORT=3001                   # market-data port (default 3001)
# PRICING_CORS_ORIGINS=*      # restrict in prod
